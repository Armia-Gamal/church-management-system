rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /leaders/{documentId} {
      allow read, write: if true;
    }

    match /members/{documentId} {
      allow read, write: if true;
    }

    match /rovers/{documentId} {
      allow read, write: if true;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
