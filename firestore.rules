rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'church@admin.com';
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    function hasAssignedMemberStage(stageValue) {
      return isAuthenticated()
        && request.auth.token.email != null
        && exists(/databases/$(database)/documents/memberStageAccess/$(request.auth.token.email.lower()))
        && get(/databases/$(database)/documents/memberStageAccess/$(request.auth.token.email.lower())).data.memberStageAccess == stageValue;
    }

    match /leaders/{documentId} {
      allow read, write: if isAdmin();
    }

    match /members/{documentId} {
      allow read: if isAdmin() || hasAssignedMemberStage(resource.data.stage);
      allow create: if isAdmin() || hasAssignedMemberStage(request.resource.data.stage);
      allow update: if isAdmin()
        || (
          hasAssignedMemberStage(resource.data.stage)
          && hasAssignedMemberStage(request.resource.data.stage)
        );
      allow delete: if isAdmin();
    }

    match /rovers/{documentId} {
      allow read, write: if isAdmin();
    }

    match /memberStageAccess/{emailId} {
      allow read: if isAdmin() || (isAuthenticated() && request.auth.token.email != null && request.auth.token.email.lower() == emailId);
      allow write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
